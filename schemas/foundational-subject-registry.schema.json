{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:lcmrp:schema:foundational-subject-registry:0.1.0",
  "title": "LCMRP Foundational Subject Registry",
  "description": "Product-independent registry of exact, versioned Layer 1 foundational research subjects. Registry presence is identity and provenance metadata, not scientific evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "registry_type", "entries"],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "artifact_type": { "const": "foundational_subject_registry" },
    "registry_type": { "const": "foundational_subject_registry" },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/subjectEntry" }
    }
  },
  "$defs": {
    "localId": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9._-]{1,127}$"
    },
    "subjectId": {
      "type": "string",
      "pattern": "^LCMRP-FSUBJ-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
    },
    "immutableDigest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "status", "value", "scope"],
      "properties": {
        "algorithm": { "const": "SHA-256" },
        "status": { "enum": ["RECORDED", "VERIFIED"] },
        "value": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "scope": { "const": "RAW_FILE_BYTES" }
      }
    },
    "immutableArtifactReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_version",
        "schema_id",
        "locator",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/localId" },
        "artifact_version": { "type": "integer", "minimum": 1 },
        "schema_id": { "type": "string", "minLength": 1 },
        "locator": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
        },
        "digest": { "$ref": "#/$defs/immutableDigest" },
        "media_type": { "type": "string", "minLength": 1 }
      }
    },
    "subjectEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_type",
        "subject_kind",
        "subject_id",
        "subject_series",
        "subject_version",
        "supersedes_subject_version",
        "supersedes_definition_digest",
        "entry_status",
        "name",
        "definition",
        "boundary",
        "definition_artifact",
        "research_layer",
        "mechanism_maturity_applicability",
        "registered_at"
      ],
      "properties": {
        "target_type": { "const": "FOUNDATIONAL_SUBJECT" },
        "subject_kind": {
          "enum": [
            "MEMORY_TAXONOMY",
            "FORMAL_MEMORY_MODEL",
            "COGNITIVE_MEMORY_CONCEPT",
            "EVALUATION_CONSTRUCT"
          ]
        },
        "subject_id": { "$ref": "#/$defs/subjectId" },
        "subject_series": { "type": "string", "minLength": 1 },
        "subject_version": { "type": "integer", "minimum": 1 },
        "supersedes_subject_version": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "supersedes_definition_digest": {
          "oneOf": [
            { "$ref": "#/$defs/immutableDigest" },
            { "type": "null" }
          ]
        },
        "entry_status": { "enum": ["ACTIVE", "SUPERSEDED", "WITHDRAWN"] },
        "name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "definition": { "type": "string", "minLength": 1 },
        "boundary": { "type": "string", "minLength": 1 },
        "definition_artifact": { "$ref": "#/$defs/immutableArtifactReference" },
        "research_layer": { "const": "LAYER_1_FOUNDATIONAL_RESEARCH" },
        "mechanism_maturity_applicability": { "const": "NOT_APPLICABLE" },
        "registered_at": { "type": "string", "format": "date-time" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "subject_version": { "const": 1 } },
            "required": ["subject_version"]
          },
          "then": {
            "properties": {
              "supersedes_subject_version": { "type": "null" },
              "supersedes_definition_digest": { "type": "null" }
            }
          },
          "else": {
            "properties": {
              "supersedes_subject_version": { "type": "integer", "minimum": 1 },
              "supersedes_definition_digest": { "$ref": "#/$defs/immutableDigest" }
            }
          }
        }
      ]
    }
  }
}
