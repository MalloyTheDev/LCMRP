{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:lcmrp:schema:foundational-study-closeout:0.1.0",
  "title": "LCMRP Foundational Study Closeout",
  "description": "Immutable Layer 1 closeout asserting that an exact frozen foundational-study record has one published terminal finding or disposition for every planned analysis.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "record_id",
    "record_version",
    "immutable_record_notice",
    "amendment",
    "record_status",
    "closeout_id",
    "research_layer",
    "study_reference",
    "completion_scope",
    "completeness_assertion",
    "analysis_dispositions",
    "closeout_report_artifact",
    "closeout_authority",
    "closed_at",
    "limitations",
    "mechanism_maturity_effect",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "artifact_type": { "const": "foundational_study_closeout" },
    "record_id": {
      "type": "string",
      "pattern": "^LCMRP-FCLOSEREC-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
    },
    "record_version": { "type": "integer", "minimum": 1 },
    "immutable_record_notice": {
      "const": "Once published, this closeout is immutable. Corrections or retractions require a new record version linked to the superseded raw-byte digest."
    },
    "amendment": { "$ref": "#/$defs/amendment" },
    "record_status": { "enum": ["DRAFT", "PUBLISHED", "SUPERSEDED", "RETRACTED"] },
    "closeout_id": {
      "type": "string",
      "pattern": "^LCMRP-FCLOSE-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
    },
    "research_layer": { "const": "LAYER_1_FOUNDATIONAL_RESEARCH" },
    "study_reference": { "$ref": "#/$defs/studyReference" },
    "completion_scope": { "const": "EXACT_STUDY_RECORD_VERSION" },
    "completeness_assertion": {
      "enum": [
        "PENDING_VALIDATION",
        "EXACTLY_ONE_PUBLISHED_FINDING_PER_PLANNED_ANALYSIS"
      ]
    },
    "analysis_dispositions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/analysisDisposition" }
    },
    "closeout_report_artifact": { "$ref": "#/$defs/immutableArtifactReference" },
    "closeout_authority": { "type": ["string", "null"], "minLength": 1 },
    "closed_at": { "type": ["string", "null"], "format": "date-time" },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "mechanism_maturity_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applicability",
        "mechanism_under_evaluation",
        "may_award_mechanism_evidence_labels",
        "may_change_mechanism_evidence_profile",
        "awarded_mechanism_evidence_labels",
        "rationale"
      ],
      "properties": {
        "applicability": { "const": "NOT_APPLICABLE" },
        "mechanism_under_evaluation": { "const": false },
        "may_award_mechanism_evidence_labels": { "const": false },
        "may_change_mechanism_evidence_profile": { "const": false },
        "awarded_mechanism_evidence_labels": { "const": [] },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": false
  },
  "allOf": [
    {
      "if": {
        "properties": { "record_version": { "const": 1 } },
        "required": ["record_version"]
      },
      "then": {
        "properties": {
          "amendment": {
            "properties": {
              "kind": { "const": "INITIAL" },
              "supersedes_record_version": { "type": "null" },
              "supersedes_artifact_digest": { "type": "null" },
              "rationale": { "type": "null" },
              "changed_fields": { "maxItems": 0 }
            }
          }
        }
      },
      "else": {
        "properties": {
          "amendment": {
            "properties": {
              "kind": { "const": "SUPERSEDING_RECORD" },
              "supersedes_record_version": { "type": "integer", "minimum": 1 },
              "supersedes_artifact_digest": { "$ref": "#/$defs/immutableDigest" },
              "rationale": { "type": "string", "minLength": 1 },
              "changed_fields": { "minItems": 1 }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "record_status": { "const": "PUBLISHED" } },
        "required": ["record_status"]
      },
      "then": {
        "properties": {
          "completeness_assertion": {
            "const": "EXACTLY_ONE_PUBLISHED_FINDING_PER_PLANNED_ANALYSIS"
          },
          "closeout_authority": { "type": "string", "minLength": 1 },
          "closed_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    {
      "if": {
        "properties": { "record_status": { "const": "DRAFT" } },
        "required": ["record_status"]
      },
      "then": {
        "properties": {
          "completeness_assertion": { "const": "PENDING_VALIDATION" },
          "closeout_authority": { "type": "null" },
          "closed_at": { "type": "null" }
        }
      }
    }
  ],
  "$defs": {
    "localId": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9._-]{1,127}$"
    },
    "amendment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "supersedes_record_version",
        "supersedes_artifact_digest",
        "rationale",
        "changed_fields"
      ],
      "properties": {
        "kind": { "enum": ["INITIAL", "SUPERSEDING_RECORD"] },
        "supersedes_record_version": { "type": ["integer", "null"], "minimum": 1 },
        "supersedes_artifact_digest": {
          "oneOf": [
            { "$ref": "#/$defs/immutableDigest" },
            { "type": "null" }
          ]
        },
        "rationale": { "type": ["string", "null"], "minLength": 1 },
        "changed_fields": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "studyReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "study_id",
        "study_record_id",
        "study_record_version",
        "manifest_artifact"
      ],
      "properties": {
        "study_id": {
          "type": "string",
          "pattern": "^LCMRP-FSTUDY-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
        },
        "study_record_id": {
          "type": "string",
          "pattern": "^LCMRP-FSTUDYREC-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
        },
        "study_record_version": { "type": "integer", "minimum": 1 },
        "manifest_artifact": {
          "allOf": [
            { "$ref": "#/$defs/immutableArtifactReference" },
            {
              "properties": {
                "schema_id": {
                  "const": "urn:lcmrp:schema:foundational-study-manifest:0.1.0"
                }
              }
            }
          ]
        }
      }
    },
    "analysisDisposition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "analysis_id",
        "analysis_mode",
        "finding_id",
        "finding_record_id",
        "finding_record_version",
        "terminal_disposition",
        "finding_artifact"
      ],
      "properties": {
        "analysis_id": { "$ref": "#/$defs/localId" },
        "analysis_mode": { "enum": ["CONFIRMATORY", "EXPLORATORY"] },
        "finding_id": {
          "type": "string",
          "pattern": "^LCMRP-FIND-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
        },
        "finding_record_id": {
          "type": "string",
          "pattern": "^LCMRP-FINDREC-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
        },
        "finding_record_version": { "type": "integer", "minimum": 1 },
        "terminal_disposition": {
          "enum": ["COMPLETED", "NOT_RUN", "HALTED", "INVALID"]
        },
        "finding_artifact": {
          "allOf": [
            { "$ref": "#/$defs/immutableArtifactReference" },
            {
              "properties": {
                "schema_id": {
                  "const": "urn:lcmrp:schema:research-finding-record:0.1.0"
                }
              }
            }
          ]
        }
      }
    },
    "immutableDigest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "status", "value", "scope"],
      "properties": {
        "algorithm": { "const": "SHA-256" },
        "status": { "enum": ["RECORDED", "VERIFIED"] },
        "value": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "scope": { "const": "RAW_FILE_BYTES" }
      }
    },
    "immutableArtifactReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_version",
        "schema_id",
        "locator",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/localId" },
        "artifact_version": { "type": "integer", "minimum": 1 },
        "schema_id": { "type": "string", "minLength": 1 },
        "locator": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
        },
        "digest": { "$ref": "#/$defs/immutableDigest" },
        "media_type": { "type": "string", "minLength": 1 }
      }
    }
  }
}
