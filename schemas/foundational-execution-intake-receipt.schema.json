{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:lcmrp:schema:foundational-execution-intake-receipt:0.1.0",
  "title": "LCMRP Foundational Execution Intake External Digest Receipt",
  "description": "External raw-byte digest receipt for a foundational execution-intake payload. The receipt binds the payload file by locator and SHA-256 over RAW_FILE_BYTES. It is not a research finding and does not authorize execution by itself.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "research_layer",
    "payload_locator",
    "payload_digest",
    "binding_mode",
    "claim_boundary"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "artifact_type": { "const": "foundational_execution_intake_receipt" },
    "artifact_id": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9._-]{1,127}$"
    },
    "artifact_version": { "type": "integer", "minimum": 1 },
    "research_layer": { "const": "LAYER_1_FOUNDATIONAL_RESEARCH" },
    "payload_locator": {
      "type": "string",
      "minLength": 1,
      "description": "Repository-relative path of the intake payload file whose raw bytes are digested."
    },
    "payload_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value", "scope", "status"],
      "properties": {
        "algorithm": { "const": "SHA-256" },
        "value": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "scope": { "const": "RAW_FILE_BYTES" },
        "status": {
          "type": "string",
          "enum": ["RECORDED", "VERIFIED"]
        }
      }
    },
    "binding_mode": { "const": "EXTERNAL_DIGEST_RECEIPT" },
    "recorded_at": { "type": "string", "format": "date-time" },
    "claim_boundary": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "example_notice": {
      "type": "string",
      "minLength": 1
    }
  }
}
