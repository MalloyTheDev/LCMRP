{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:lcmrp:schema:foundational-study-manifest:0.1.0",
  "title": "LCMRP Foundational Study Manifest",
  "description": "Layer 1 contract for a mechanism-free foundational study. It cannot target or award a mechanism evidence-state label.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "study_record_id",
    "record_version",
    "immutable_record_notice",
    "amendment",
    "preregistration",
    "record_status",
    "study_id",
    "research_layer",
    "subject",
    "primary_method_profile",
    "research_question",
    "hypothesis",
    "analyses",
    "sources",
    "reproducibility",
    "rejection_criteria",
    "ethics_scope",
    "security_and_privacy_analysis",
    "limitations",
    "mechanism_maturity_boundary",
    "protocol_artifact",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "artifact_type": { "const": "foundational_study_manifest" },
    "study_record_id": {
      "type": "string",
      "pattern": "^LCMRP-FSTUDYREC-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
    },
    "record_version": { "type": "integer", "minimum": 1 },
    "immutable_record_notice": {
      "const": "Once frozen, this study manifest is immutable. Changes require a new record version linked to the superseded raw-byte digest."
    },
    "amendment": { "$ref": "#/$defs/amendment" },
    "preregistration": { "$ref": "#/$defs/preregistration" },
    "record_status": { "enum": ["DRAFT", "FROZEN", "SUPERSEDED", "WITHDRAWN"] },
    "study_id": {
      "type": "string",
      "pattern": "^LCMRP-FSTUDY-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
    },
    "research_layer": { "const": "LAYER_1_FOUNDATIONAL_RESEARCH" },
    "subject": { "$ref": "#/$defs/foundationalSubject" },
    "primary_method_profile": { "$ref": "#/$defs/primaryMethodProfile" },
    "research_question": { "type": "string", "minLength": 1 },
    "hypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "competing_explanation", "predicted_observation", "falsifier"],
      "properties": {
        "claim": { "type": "string", "minLength": 1 },
        "competing_explanation": { "type": "string", "minLength": 1 },
        "predicted_observation": { "type": "string", "minLength": 1 },
        "falsifier": { "type": "string", "minLength": 1 }
      }
    },
    "analyses": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/plannedAnalysis" }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source" }
    },
    "reproducibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_revision", "environment_artifact", "configuration_artifacts", "replication_criteria"],
      "properties": {
        "source_revision": { "type": "string", "minLength": 1 },
        "environment_artifact": { "$ref": "#/$defs/artifactReference" },
        "configuration_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/artifactReference" }
        },
        "replication_criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "rejection_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["criterion_id", "condition", "disposition", "rationale"],
        "properties": {
          "criterion_id": { "$ref": "#/$defs/localId" },
          "condition": { "type": "string", "minLength": 1 },
          "disposition": { "enum": ["REJECT_CLAIM", "MARK_INCONCLUSIVE", "HALT_STUDY", "INVALIDATE_ANALYSIS"] },
          "rationale": { "type": "string", "minLength": 1 }
        }
      }
    },
    "ethics_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["human_subjects_involved", "human_participant_data_involved", "rationale"],
      "properties": {
        "human_subjects_involved": { "const": false },
        "human_participant_data_involved": { "const": false },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "security_and_privacy_analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assets", "threats", "controls", "data_retention_and_deletion", "residual_risks"],
      "properties": {
        "assets": { "$ref": "#/$defs/nonEmptyStrings" },
        "threats": { "$ref": "#/$defs/nonEmptyStrings" },
        "controls": { "$ref": "#/$defs/nonEmptyStrings" },
        "data_retention_and_deletion": { "type": "string", "minLength": 1 },
        "residual_risks": { "$ref": "#/$defs/nonEmptyStrings" }
      }
    },
    "limitations": { "$ref": "#/$defs/nonEmptyStrings" },
    "mechanism_maturity_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applicability",
        "mechanism_under_evaluation",
        "may_award_mechanism_evidence_labels",
        "may_change_mechanism_evidence_profile",
        "rationale"
      ],
      "properties": {
        "applicability": { "const": "NOT_APPLICABLE" },
        "mechanism_under_evaluation": { "const": false },
        "may_award_mechanism_evidence_labels": { "const": false },
        "may_change_mechanism_evidence_profile": { "const": false },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "protocol_artifact": { "$ref": "#/$defs/artifactReference" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": false
  },
  "allOf": [
    {
      "if": { "properties": { "record_version": { "const": 1 } }, "required": ["record_version"] },
      "then": {
        "properties": {
          "amendment": {
            "properties": {
              "kind": { "const": "INITIAL" },
              "supersedes_record_version": { "type": "null" },
              "supersedes_artifact_digest": { "type": "null" },
              "result_accessed_before_amendment": { "const": false },
              "changed_fields": { "maxItems": 0 },
              "post_result_change_disclosure": { "type": "null" }
            }
          }
        }
      },
      "else": {
        "properties": {
          "amendment": {
            "properties": {
              "kind": { "const": "SUPERSEDING_RECORD" },
              "supersedes_record_version": { "type": "integer", "minimum": 1 },
              "supersedes_artifact_digest": { "$ref": "#/$defs/immutableDigest" },
              "changed_fields": { "minItems": 1 }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "amendment": {
            "properties": { "result_accessed_before_amendment": { "const": true } },
            "required": ["result_accessed_before_amendment"]
          }
        },
        "required": ["amendment"]
      },
      "then": {
        "properties": {
          "amendment": {
            "properties": { "post_result_change_disclosure": { "type": "string", "minLength": 1 } }
          },
          "analyses": {
            "items": { "properties": { "analysis_mode": { "const": "EXPLORATORY" } } }
          }
        }
      }
    },
    {
      "if": { "properties": { "record_status": { "const": "FROZEN" } }, "required": ["record_status"] },
      "then": {
        "properties": {
          "preregistration": {
            "properties": {
              "status": { "const": "FROZEN" },
              "results_accessed_before_freeze": { "const": false },
              "frozen_at": { "type": "string", "format": "date-time" },
              "registration_authority": { "type": "string", "minLength": 1 },
              "freeze_artifact": { "$ref": "#/$defs/immutableArtifactReference" }
            }
          },
          "subject": {
            "properties": { "definition_artifact": { "$ref": "#/$defs/immutableArtifactReference" } }
          },
          "primary_method_profile": {
            "properties": {
              "profile_definition_artifact": { "$ref": "#/$defs/immutableArtifactReference" },
              "category_definition_artifact": { "$ref": "#/$defs/immutableArtifactReference" },
              "formal_system_artifact": { "$ref": "#/$defs/immutableArtifactReference" }
            }
          },
          "sources": {
            "items": {
              "properties": {
                "provenance_artifact": { "$ref": "#/$defs/immutableArtifactReference" }
              }
            }
          },
          "reproducibility": {
            "properties": {
              "environment_artifact": { "$ref": "#/$defs/immutableArtifactReference" },
              "configuration_artifacts": {
                "items": { "$ref": "#/$defs/immutableArtifactReference" }
              }
            }
          },
          "protocol_artifact": { "$ref": "#/$defs/immutableArtifactReference" }
        }
      }
    },
    {
      "if": { "properties": { "record_status": { "const": "DRAFT" } }, "required": ["record_status"] },
      "then": {
        "properties": {
          "preregistration": {
            "properties": {
              "status": { "const": "DRAFT" },
              "results_accessed_before_freeze": { "const": false },
              "frozen_at": { "type": "null" },
              "registration_authority": { "type": "null" },
              "freeze_artifact": { "type": "null" }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "localId": { "type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]{1,127}$" },
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "amendment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "supersedes_record_version",
        "supersedes_artifact_digest",
        "rationale",
        "changed_fields",
        "result_accessed_before_amendment",
        "post_result_change_disclosure"
      ],
      "properties": {
        "kind": { "enum": ["INITIAL", "SUPERSEDING_RECORD"] },
        "supersedes_record_version": { "type": ["integer", "null"], "minimum": 1 },
        "supersedes_artifact_digest": {
          "oneOf": [{ "$ref": "#/$defs/immutableDigest" }, { "type": "null" }]
        },
        "rationale": { "type": ["string", "null"], "minLength": 1 },
        "changed_fields": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "result_accessed_before_amendment": { "type": "boolean" },
        "post_result_change_disclosure": { "type": ["string", "null"], "minLength": 1 }
      }
    },
    "preregistration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "results_accessed_before_freeze",
        "frozen_at",
        "registration_authority",
        "freeze_artifact"
      ],
      "properties": {
        "status": { "enum": ["DRAFT", "FROZEN"] },
        "results_accessed_before_freeze": { "type": "boolean" },
        "frozen_at": { "type": ["string", "null"], "format": "date-time" },
        "registration_authority": { "type": ["string", "null"], "minLength": 1 },
        "freeze_artifact": {
          "oneOf": [
            { "$ref": "#/$defs/immutableArtifactReference" },
            { "type": "null" }
          ]
        }
      }
    },
    "foundationalSubject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_type",
        "subject_kind",
        "subject_id",
        "subject_series",
        "subject_version",
        "name",
        "definition",
        "boundary",
        "definition_artifact"
      ],
      "properties": {
        "target_type": { "const": "FOUNDATIONAL_SUBJECT" },
        "subject_kind": {
          "enum": ["MEMORY_TAXONOMY", "FORMAL_MEMORY_MODEL", "COGNITIVE_MEMORY_CONCEPT", "EVALUATION_CONSTRUCT"]
        },
        "subject_id": {
          "type": "string",
          "pattern": "^LCMRP-FSUBJ-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
        },
        "subject_series": { "type": "string", "minLength": 1 },
        "subject_version": { "type": "integer", "minimum": 1 },
        "name": { "type": "string", "minLength": 1 },
        "definition": { "type": "string", "minLength": 1 },
        "boundary": { "type": "string", "minLength": 1 },
        "definition_artifact": { "$ref": "#/$defs/artifactReference" }
      }
    },
    "primaryMethodProfile": {
      "oneOf": [
        { "$ref": "#/$defs/structuralTaxonomyProfile" },
        { "$ref": "#/$defs/formalAnalysisProfile" }
      ]
    },
    "profileIdentity": {
      "type": "object",
      "required": ["profile_id", "profile_series", "profile_version", "profile_definition_artifact"],
      "properties": {
        "profile_id": {
          "type": "string",
          "pattern": "^LCMRP-MPROF-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
        },
        "profile_series": { "type": "string", "minLength": 1 },
        "profile_version": { "type": "integer", "minimum": 1 },
        "profile_definition_artifact": { "$ref": "#/$defs/artifactReference" }
      }
    },
    "structuralTaxonomyProfile": {
      "allOf": [
        { "$ref": "#/$defs/profileIdentity" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "profile_kind",
            "profile_id",
            "profile_series",
            "profile_version",
            "profile_definition_artifact",
            "category_definition_artifact",
            "competency_questions",
            "integrity_constraints",
            "positive_case_source_ids",
            "negative_case_source_ids",
            "adjudication_method",
            "coverage_rule"
          ],
          "properties": {
            "profile_kind": { "const": "STRUCTURAL_OR_TAXONOMY_EVALUATION" },
            "profile_id": true,
            "profile_series": true,
            "profile_version": true,
            "profile_definition_artifact": true,
            "category_definition_artifact": { "$ref": "#/$defs/artifactReference" },
            "competency_questions": { "$ref": "#/$defs/nonEmptyStrings" },
            "integrity_constraints": { "$ref": "#/$defs/nonEmptyStrings" },
            "positive_case_source_ids": { "$ref": "#/$defs/nonEmptyLocalIds" },
            "negative_case_source_ids": { "$ref": "#/$defs/nonEmptyLocalIds" },
            "adjudication_method": { "type": "string", "minLength": 1 },
            "coverage_rule": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "formalAnalysisProfile": {
      "allOf": [
        { "$ref": "#/$defs/profileIdentity" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "profile_kind",
            "profile_id",
            "profile_series",
            "profile_version",
            "profile_definition_artifact",
            "formal_system_artifact",
            "assumptions",
            "propositions",
            "consistency_or_satisfiability_checks",
            "intended_entailments",
            "non_entailments_or_countermodels",
            "tool_provenance",
            "proof_or_verification_method",
            "semantic_validity_check",
            "counterexample_search"
          ],
          "properties": {
            "profile_kind": { "const": "FORMAL_ANALYSIS" },
            "profile_id": true,
            "profile_series": true,
            "profile_version": true,
            "profile_definition_artifact": true,
            "formal_system_artifact": { "$ref": "#/$defs/artifactReference" },
            "assumptions": { "$ref": "#/$defs/nonEmptyStrings" },
            "propositions": { "$ref": "#/$defs/nonEmptyLocalIds" },
            "consistency_or_satisfiability_checks": { "$ref": "#/$defs/nonEmptyStrings" },
            "intended_entailments": { "$ref": "#/$defs/nonEmptyStrings" },
            "non_entailments_or_countermodels": { "$ref": "#/$defs/nonEmptyStrings" },
            "tool_provenance": { "$ref": "#/$defs/immutableArtifactReference" },
            "proof_or_verification_method": { "type": "string", "minLength": 1 },
            "semantic_validity_check": { "type": "string", "minLength": 1 },
            "counterexample_search": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "nonEmptyLocalIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/localId" }
    },
    "plannedAnalysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "analysis_id",
        "analysis_mode",
        "question",
        "method",
        "decision_rule",
        "planned_output_artifact",
        "required_terminal_dispositions"
      ],
      "properties": {
        "analysis_id": { "$ref": "#/$defs/localId" },
        "analysis_mode": { "enum": ["CONFIRMATORY", "EXPLORATORY"] },
        "question": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "decision_rule": { "type": "string", "minLength": 1 },
        "planned_output_artifact": { "$ref": "#/$defs/artifactReference" },
        "required_terminal_dispositions": {
          "const": ["COMPLETED", "NOT_RUN", "HALTED", "INVALID"]
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_kind", "role", "human_subjects_involved", "provenance_artifact"],
      "properties": {
        "source_id": { "$ref": "#/$defs/localId" },
        "source_kind": { "enum": ["SYNTHETIC_CASE_SET", "FORMAL_SPECIFICATION", "PUBLICATION_CORPUS", "OTHER_NON_HUMAN_SOURCE"] },
        "role": { "enum": ["DEVELOPMENT", "POSITIVE_CASES", "NEGATIVE_CASES", "HELD_OUT_EVALUATION", "FORMAL_INPUT", "PRIOR_WORK"] },
        "human_subjects_involved": { "const": false },
        "provenance_artifact": { "$ref": "#/$defs/artifactReference" }
      }
    },
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "status", "value", "scope"],
      "properties": {
        "algorithm": { "const": "SHA-256" },
        "status": { "enum": ["PENDING", "RECORDED", "VERIFIED"] },
        "value": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "scope": { "const": "RAW_FILE_BYTES" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "PENDING" } }, "required": ["status"] },
          "then": { "properties": { "value": { "type": "null" } } },
          "else": { "properties": { "value": { "type": "string", "pattern": "^[a-f0-9]{64}$" } } }
        }
      ]
    },
    "immutableDigest": {
      "allOf": [
        { "$ref": "#/$defs/digest" },
        { "properties": { "status": { "enum": ["RECORDED", "VERIFIED"] }, "value": { "type": "string" } } }
      ]
    },
    "artifactReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "artifact_version", "schema_id", "locator", "digest", "media_type"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/localId" },
        "artifact_version": { "type": "integer", "minimum": 1 },
        "schema_id": { "type": "string", "minLength": 1 },
        "locator": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$" },
        "digest": { "$ref": "#/$defs/digest" },
        "media_type": { "type": "string", "minLength": 1 }
      }
    },
    "immutableArtifactReference": {
      "allOf": [
        { "$ref": "#/$defs/artifactReference" },
        { "properties": { "digest": { "$ref": "#/$defs/immutableDigest" } } }
      ]
    }
  }
}
