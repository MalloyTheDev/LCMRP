    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "status", "value"],
      "properties": {
        "algorithm": {
          "enum": ["sha256", "sha384", "sha512", "blake3"]
        },
        "status": {
          "enum": ["PENDING", "RECORDED", "VERIFIED"]
        },
        "value": {
          "type": ["string", "null"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "PENDING"
              }
            },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "value": {
                "type": "null"
              }
            }
          },
          "else": {
            "properties": {
              "value": {
                "type": "string"
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "algorithm": {
                      "enum": ["sha256", "blake3"]
                    }
                  },
                  "required": ["algorithm"]
                },
                "then": {
                  "properties": {
                    "value": {
                      "pattern": "^[a-f0-9]{64}$"
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "algorithm": {
                      "const": "sha384"
                    }
                  },
                  "required": ["algorithm"]
                },
                "then": {
                  "properties": {
                    "value": {
                      "pattern": "^[a-f0-9]{96}$"
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "algorithm": {
                      "const": "sha512"
                    }
                  },
                  "required": ["algorithm"]
                },
                "then": {
                  "properties": {
                    "value": {
                      "pattern": "^[a-f0-9]{128}$"
                    }
                  }
                }
              }
            ]
          }
        }
      ]
    },
    "recordedOrVerifiedDigest": {
      "description": "A materialized digest suitable for immutable lineage. PENDING and null values are prohibited.",
      "allOf": [
        {
          "$ref": "#/$defs/digest"
        },
        {
          "properties": {
            "status": {
              "enum": ["RECORDED", "VERIFIED"]
            },
            "value": {
              "type": "string"
            }
          }
        }
      ]
    },
