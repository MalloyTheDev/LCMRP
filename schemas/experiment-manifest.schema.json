{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:lcmrp:schema:experiment-manifest:0.1.0",
  "title": "LCMRP Experiment Manifest",
  "description": "Product-independent, preregistration-oriented contract for an LCMRP experiment.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "manifest_record_id",
    "record_version",
    "immutable_record_notice",
    "amendment",
    "preregistration",
    "analysis_mode",
    "experiment_id",
    "title",
    "research_layer",
    "lifecycle_status",
    "research_question",
    "hypothesis",
    "mechanism_versions",
    "experimental_design",
    "baselines",
    "datasets_or_scenarios",
    "held_out_evaluation",
    "metrics",
    "reproducibility",
    "analysis_plan",
    "rejection_criteria",
    "security_and_privacy_analysis",
    "limitations",
    "target_evidence_state",
    "artifacts",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "artifact_type": {
      "const": "experiment_manifest"
    },
    "manifest_record_id": {
      "type": "string",
      "pattern": "^LCMRP-EXPMAN-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
    },
    "record_version": {
      "type": "integer",
      "minimum": 1
    },
    "immutable_record_notice": {
      "const": "Once frozen, this manifest record must not be modified. Any amendment must create a new record version that references the superseded record."
    },
    "amendment": {
      "$ref": "#/$defs/amendment"
    },
    "preregistration": {
      "$ref": "#/$defs/preregistration"
    },
    "analysis_mode": {
      "description": "Classification of the analyses governed by this manifest. Post-result amendments are necessarily EXPLORATORY.",
      "enum": ["CONFIRMATORY", "EXPLORATORY"]
    },
    "experiment_id": {
      "$ref": "#/$defs/experimentId"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "research_layer": {
      "$ref": "#/$defs/researchLayer"
    },
    "lifecycle_status": {
      "enum": [
        "DRAFT",
        "PLANNED",
        "RUNNING",
        "COMPLETED",
        "HALTED",
        "CANCELLED",
        "SUPERSEDED"
      ]
    },
    "research_question": {
      "type": "string",
      "minLength": 1
    },
    "hypothesis": {
      "$ref": "#/$defs/hypothesis"
    },
    "mechanism_versions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mechanismVersionReference"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "experimental_design": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "design_type",
        "unit_of_analysis",
        "procedure",
        "controls",
        "ablation_plan",
        "boundary_and_adversarial_tests",
        "stopping_rules"
      ],
      "properties": {
        "design_type": {
          "type": "string",
          "minLength": 1
        },
        "unit_of_analysis": {
          "type": "string",
          "minLength": 1
        },
        "procedure": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "controls": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "ablation_plan": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ablation_id", "component_removed_or_changed", "rationale"],
            "properties": {
              "ablation_id": {
                "$ref": "#/$defs/localId"
              },
              "component_removed_or_changed": {
                "type": "string",
                "minLength": 1
              },
              "rationale": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "minItems": 1
        },
        "boundary_and_adversarial_tests": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["test_id", "category", "description", "expected_safe_behavior"],
            "properties": {
              "test_id": {
                "$ref": "#/$defs/localId"
              },
              "category": {
                "enum": [
                  "BOUNDARY",
                  "ADVERSARIAL",
                  "DISTRIBUTION_SHIFT",
                  "CORRUPTION",
                  "PRIVACY",
                  "SECURITY",
                  "OTHER"
                ]
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "expected_safe_behavior": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "minItems": 1
        },
        "stopping_rules": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "baselines": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/baseline"
      },
      "minItems": 1
    },
    "datasets_or_scenarios": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/datasetOrScenario"
      },
      "minItems": 1
    },
    "held_out_evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["applicability", "rationale", "source_ids"],
      "properties": {
        "applicability": {
          "enum": ["APPLICABLE", "NOT_APPLICABLE"]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "source_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/localId"
          },
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "applicability": {
                "const": "APPLICABLE"
              }
            },
            "required": ["applicability"]
          },
          "then": {
            "properties": {
              "source_ids": {
                "minItems": 1
              }
            }
          },
          "else": {
            "properties": {
              "source_ids": {
                "maxItems": 0
              }
            }
          }
        }
      ]
    },
    "metrics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/metric"
      },
      "minItems": 1
    },
    "reproducibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "randomness",
        "model_provenance",
        "environment_provenance",
        "configuration_artifacts",
        "replication_criteria"
      ],
      "properties": {
        "randomness": {
          "$ref": "#/$defs/randomness"
        },
        "model_provenance": {
          "$ref": "#/$defs/modelProvenanceSet"
        },
        "environment_provenance": {
          "$ref": "#/$defs/environmentProvenance"
        },
        "configuration_artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactReference"
          },
          "minItems": 1
        },
        "replication_criteria": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "analysis_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comparison_method",
        "uncertainty_method",
        "missing_data_policy",
        "multiple_comparison_policy",
        "qualitative_analysis"
      ],
      "properties": {
        "comparison_method": {
          "type": "string",
          "minLength": 1
        },
        "uncertainty_method": {
          "type": "string",
          "minLength": 1
        },
        "missing_data_policy": {
          "type": "string",
          "minLength": 1
        },
        "multiple_comparison_policy": {
          "type": "string",
          "minLength": 1
        },
        "qualitative_analysis": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "rejection_criteria": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rejectionCriterion"
      },
      "minItems": 1
    },
    "security_and_privacy_analysis": {
      "$ref": "#/$defs/securityAndPrivacyAnalysis"
    },
    "limitations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/limitation"
      },
      "minItems": 1
    },
    "target_evidence_state": {
      "type": "object",
      "description": "A research target only. It does not award or imply that the named evidence state has been earned.",
      "additionalProperties": false,
      "required": ["state_under_investigation", "award_requires_separate_evidence_record", "rationale"],
      "properties": {
        "state_under_investigation": {
          "$ref": "#/$defs/evidenceState"
        },
        "award_requires_separate_evidence_record": {
          "const": true
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifactReference"
      },
      "minItems": 1
    },
    "future_corpusstudio_integration_implications": {
      "$ref": "#/$defs/corpusStudioImplications"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": false
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "research_layer": {
            "const": "LAYER_3_FUTURE_CORPUSSTUDIO_INTEGRATION"
          }
        },
        "required": ["research_layer"]
      },
      "then": {
        "required": ["future_corpusstudio_integration_implications"]
      }
    },
    {
      "if": {
        "properties": {
          "record_version": {
            "const": 1
          }
        },
        "required": ["record_version"]
      },
      "then": {
        "properties": {
          "amendment": {
            "properties": {
              "kind": {
                "const": "INITIAL"
              },
              "supersedes_record_version": {
                "type": "null"
              },
              "supersedes_artifact_digest": {
                "type": "null"
              },
              "rationale": {
                "type": "null"
              },
              "changed_fields": {
                "maxItems": 0
              },
              "result_accessed_before_amendment": {
                "const": false
              },
              "post_result_change_disclosure": {
                "type": "null"
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "amendment": {
            "properties": {
              "kind": {
                "enum": ["PRE_RESULT_AMENDMENT", "POST_RESULT_AMENDMENT"]
              },
              "supersedes_record_version": {
                "type": "integer",
                "minimum": 1
              },
              "supersedes_artifact_digest": {
                "$ref": "#/$defs/recordedOrVerifiedDigest"
              },
              "rationale": {
                "type": "string"
              },
              "changed_fields": {
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "properties": {
        "target_evidence_state": {
          "properties": {
            "state_under_investigation": {
              "not": {
                "const": "PRODUCTION_READY"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "research_layer": {
            "enum": [
              "LAYER_1_FOUNDATIONAL_RESEARCH",
              "LAYER_2_PRODUCT_INDEPENDENT_REFERENCE_IMPLEMENTATION"
            ]
          }
        },
        "required": ["research_layer"]
      },
      "then": {
        "properties": {
          "target_evidence_state": {
            "properties": {
              "state_under_investigation": {
                "not": {
                  "const": "INTEGRATION_CANDIDATE"
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "amendment": {
            "properties": {
              "kind": {
                "const": "POST_RESULT_AMENDMENT"
              }
            },
            "required": ["kind"]
          }
        },
        "required": ["amendment"]
      },
      "then": {
        "properties": {
          "analysis_mode": {
            "const": "EXPLORATORY"
          },
          "preregistration": {
            "properties": {
              "status": {
                "const": "FROZEN"
              },
              "result_access_status": {
                "const": "STARTED"
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "amendment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "supersedes_record_version",
        "supersedes_artifact_digest",
        "rationale",
        "changed_fields",
        "result_accessed_before_amendment",
        "post_result_change_disclosure"
      ],
      "properties": {
        "kind": {
          "enum": ["INITIAL", "PRE_RESULT_AMENDMENT", "POST_RESULT_AMENDMENT"]
        },
        "supersedes_record_version": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "supersedes_artifact_digest": {
          "oneOf": [
            {
              "$ref": "#/$defs/recordedOrVerifiedDigest"
            },
            {
              "type": "null"
            }
          ]
        },
        "rationale": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "changed_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "result_accessed_before_amendment": {
          "type": "boolean"
        },
        "post_result_change_disclosure": {
          "description": "For a post-result amendment, discloses what changed after result access and how that timing limits interpretation. Null for initial and pre-result records.",
          "type": ["string", "null"],
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "PRE_RESULT_AMENDMENT"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "result_accessed_before_amendment": {
                "const": false
              },
              "post_result_change_disclosure": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "POST_RESULT_AMENDMENT"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "result_accessed_before_amendment": {
                "const": true
              },
              "post_result_change_disclosure": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "preregistration": {
      "type": "object",
      "description": "Freeze evidence is held in an external registration envelope so this manifest never embeds a digest of bytes that include the digest itself.",
      "additionalProperties": false,
      "required": [
        "status",
        "frozen_at",
        "external_registration_envelope",
        "result_access_status",
        "result_access_started_at"
      ],
      "properties": {
        "status": {
          "enum": ["DRAFT", "FROZEN"]
        },
        "frozen_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "external_registration_envelope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "envelope_id", "locator"],
          "properties": {
            "status": {
              "enum": ["NOT_CREATED", "REGISTERED"]
            },
            "envelope_id": {
              "type": ["string", "null"],
              "minLength": 1
            },
            "locator": {
              "type": ["string", "null"],
              "minLength": 1
            }
          }
        },
        "result_access_status": {
          "enum": ["NOT_STARTED", "STARTED"]
        },
        "result_access_started_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "DRAFT"
              }
            },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "frozen_at": {
                "type": "null"
              },
              "external_registration_envelope": {
                "properties": {
                  "status": {
                    "const": "NOT_CREATED"
                  },
                  "envelope_id": {
                    "type": "null"
                  },
                  "locator": {
                    "type": "null"
                  }
                }
              },
              "result_access_status": {
                "const": "NOT_STARTED"
              },
              "result_access_started_at": {
                "type": "null"
              }
            }
          },
          "else": {
            "properties": {
              "frozen_at": {
                "type": "string"
              },
              "external_registration_envelope": {
                "properties": {
                  "status": {
                    "const": "REGISTERED"
                  },
                  "envelope_id": {
                    "type": "string"
                  },
                  "locator": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "result_access_status": {
                "const": "NOT_STARTED"
              }
            },
            "required": ["result_access_status"]
          },
          "then": {
            "properties": {
              "result_access_started_at": {
                "type": "null"
              }
            }
          },
          "else": {
            "properties": {
              "result_access_started_at": {
                "type": "string"
              }
            }
          }
        }
      ]
    },
    "localId": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9._-]{1,127}$"
    },
    "experimentId": {
      "type": "string",
      "pattern": "^LCMRP-EXP-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
    },
    "mechanismId": {
      "type": "string",
      "pattern": "^LCMRP-MECH-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
    },
    "mechanismVersionReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mechanism_id", "mechanism_version", "mechanism_artifact"],
      "properties": {
        "mechanism_id": {
          "$ref": "#/$defs/mechanismId"
        },
        "mechanism_version": {
          "type": "integer",
          "minimum": 1
        },
        "mechanism_artifact": {
          "allOf": [
            {
              "$ref": "#/$defs/artifactReference"
            },
            {
              "properties": {
                "digest": {
                  "properties": {
                    "status": {
                      "enum": ["RECORDED", "VERIFIED"]
                    },
                    "value": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          ]
        }
      }
    },
    "researchLayer": {
      "enum": [
        "LAYER_1_FOUNDATIONAL_RESEARCH",
        "LAYER_2_PRODUCT_INDEPENDENT_REFERENCE_IMPLEMENTATION",
        "LAYER_3_FUTURE_CORPUSSTUDIO_INTEGRATION"
      ]
    },
    "evidenceState": {
      "enum": [
        "HYPOTHESIS",
        "PROTOTYPE",
        "REPLICATED",
        "BENCHMARKED",
        "ROBUSTNESS_TESTED",
        "SECURITY_REVIEWED",
        "INDEPENDENTLY_VALIDATED",
        "INTEGRATION_CANDIDATE",
        "PRODUCTION_READY"
      ]
    },
    "hypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "statement",
        "falsifiable_prediction",
        "null_hypothesis",
        "independent_variables",
        "dependent_variables",
        "assumptions"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "falsifiable_prediction": {
          "type": "string",
          "minLength": 1
        },
        "null_hypothesis": {
          "type": "string",
          "minLength": 1
        },
        "independent_variables": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "dependent_variables": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseline_id", "name", "description", "rationale", "configuration_artifact"],
      "properties": {
        "baseline_id": {
          "$ref": "#/$defs/localId"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "configuration_artifact": {
          "$ref": "#/$defs/artifactReference"
        }
      }
    },
    "datasetOrScenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "kind",
        "name",
        "version",
        "role",
        "description",
        "provenance",
        "license_or_terms",
        "sensitivity_classification"
      ],
      "properties": {
        "source_id": {
          "$ref": "#/$defs/localId"
        },
        "kind": {
          "description": "Source kind. USER_STUDY is intentionally prohibited in schema v0.1.0 until LCMRP adopts a human-subject governance contract. OTHER must not be used to encode a user study.",
          "enum": [
            "DATASET",
            "SCENARIO_SUITE",
            "SIMULATION",
            "SYNTHETIC_GENERATOR",
            "OTHER"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": [
            "DEVELOPMENT",
            "VALIDATION",
            "HELD_OUT_TEST",
            "ADVERSARIAL",
            "ROBUSTNESS",
            "OTHER"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "provenance": {
          "$ref": "#/$defs/artifactReference"
        },
        "license_or_terms": {
          "type": "string",
          "minLength": 1
        },
        "sensitivity_classification": {
          "enum": [
            "PUBLIC",
            "INTERNAL",
            "CONFIDENTIAL",
            "RESTRICTED",
            "SYNTHETIC_NO_PERSONAL_DATA"
          ]
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_id",
        "name",
        "operational_definition",
        "direction",
        "unit",
        "aggregation",
        "success_criterion"
      ],
      "properties": {
        "metric_id": {
          "$ref": "#/$defs/localId"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "operational_definition": {
          "type": "string",
