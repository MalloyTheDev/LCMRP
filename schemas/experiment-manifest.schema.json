          "uniqueItems": true
        },
        "determinism_notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "applicability": {
                "const": "STOCHASTIC"
              }
            },
            "required": ["applicability"]
          },
          "then": {
            "properties": {
              "seeds": {
                "minItems": 1
              }
            }
          },
          "else": {
            "properties": {
              "seeds": {
                "maxItems": 0
              }
            }
          }
        }
      ]
    },
