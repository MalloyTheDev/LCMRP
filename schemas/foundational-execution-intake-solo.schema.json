{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:lcmrp:schema:foundational-execution-intake-solo:0.1.0",
  "title": "LCMRP Solo Foundational Execution Intake Payload",
  "description": "Intake payload for solo-human structural/taxonomy adjudication with optional non-adjudicative AI tooling. Not multi-primary human intake. Schema validity is not eligibility proof or scientific evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "research_layer",
    "study_id",
    "study_record",
    "method_profile_version",
    "research_lead",
    "ai_tooling_disclosure",
    "dual_role_disclosure",
    "results_accessed_before_intake",
    "planned_outputs_absent",
    "intake_timestamp",
    "execution_authority",
    "digest_binding",
    "claim_boundary"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "artifact_type": { "const": "foundational_execution_intake_solo" },
    "artifact_id": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9._-]{1,127}$"
    },
    "artifact_version": { "type": "integer", "minimum": 1 },
    "research_layer": { "const": "LAYER_1_FOUNDATIONAL_RESEARCH" },
    "study_id": {
      "type": "string",
      "pattern": "^LCMRP-FSTUDY-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
    },
    "study_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "study_record_id",
        "record_version",
        "manifest_locator",
        "manifest_digest"
      ],
      "properties": {
        "study_record_id": {
          "type": "string",
          "pattern": "^LCMRP-FSTUDYREC-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
        },
        "record_version": { "type": "integer", "minimum": 1 },
        "manifest_locator": { "type": "string", "minLength": 1 },
        "manifest_digest": {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "value", "scope"],
          "properties": {
            "algorithm": { "const": "SHA-256" },
            "value": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "scope": { "const": "RAW_FILE_BYTES" },
            "status": { "type": "string", "enum": ["RECORDED", "VERIFIED", "PENDING"] }
          }
        }
      }
    },
    "method_profile_version": { "type": "integer", "minimum": 2 },
    "research_lead": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contributor_id",
        "contributor_kind",
        "eligibility_declaration",
        "conflict_declaration",
        "isolation_declaration",
        "no_prior_prohibited_access_declaration",
        "accepts_exploratory_dual_role_limitations"
      ],
      "properties": {
        "contributor_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!LCMRP-AGENT)(?!AGENT-)(?!MODEL-).+"
        },
        "contributor_kind": { "const": "HUMAN_RESEARCH_CONTRIBUTOR" },
        "display_name": { "type": "string", "minLength": 1 },
        "eligibility_declaration": { "type": "string", "minLength": 1 },
        "conflict_declaration": { "type": "string", "minLength": 1 },
        "isolation_declaration": { "type": "string", "minLength": 1 },
        "no_prior_prohibited_access_declaration": { "type": "string", "minLength": 1 },
        "accepts_exploratory_dual_role_limitations": { "const": true },
        "is_protocol_author": { "type": "boolean" },
        "is_freeze_authority": { "type": "boolean" }
      }
    },
    "ai_tooling_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ai_used",
        "ai_casts_final_codes",
        "ai_roles_permitted",
        "human_final_authority_assertion"
      ],
      "properties": {
        "ai_used": { "type": "boolean" },
        "ai_casts_final_codes": { "const": false },
        "ai_roles_permitted": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "FORMATTING",
              "NAVIGATION",
              "PACKET_GENERATION",
              "DRAFT_RATIONALE_PROPOSAL",
              "DOCUMENTATION"
            ]
          }
        },
        "systems_or_models_note": { "type": "string" },
        "human_final_authority_assertion": { "type": "string", "minLength": 1 }
      }
    },
    "dual_role_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["author_or_freeze_dual_role", "independent_validation", "statement"],
      "properties": {
        "author_or_freeze_dual_role": { "type": "boolean" },
        "independent_validation": { "const": false },
        "statement": { "type": "string", "minLength": 1 }
      }
    },
    "results_accessed_before_intake": { "const": false },
    "planned_outputs_absent": { "const": true },
    "case_packets_accessed_before_intake": { "const": false },
    "intake_timestamp": { "type": "string", "format": "date-time" },
    "execution_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "authority_basis"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "authority_basis": { "type": "string", "minLength": 1 }
      }
    },
    "digest_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "receipt_schema_id",
        "forbidden_self_digest_of_entire_payload_file"
      ],
      "properties": {
        "mode": { "const": "EXTERNAL_DIGEST_RECEIPT" },
        "receipt_schema_id": {
          "const": "urn:lcmrp:schema:foundational-execution-intake-receipt:0.1.0"
        },
        "receipt_locator": { "type": "string", "minLength": 1 },
        "forbidden_self_digest_of_entire_payload_file": { "const": true }
      }
    },
    "claim_boundary": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "example_notice": { "type": "string", "minLength": 1 }
  }
}
