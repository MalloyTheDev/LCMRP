{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:lcmrp:schema:research-finding-record:0.1.0",
  "title": "LCMRP Foundational Research Finding Record",
  "description": "Layer 1 record for an atomic mechanism-independent finding or terminal analysis disposition. It cannot award or change a mechanism evidence-state label.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "record_id",
    "record_version",
    "immutable_record_notice",
    "amendment",
    "record_status",
    "finding_id",
    "research_layer",
    "study_reference",
    "subject_reference",
    "primary_method_profile_reference",
    "analysis_reference",
    "claim",
    "terminal_disposition",
    "result_classification",
    "claim_assessment",
    "result_assessment_orthogonality_notice",
    "finding_statement",
    "uncertainty",
    "raw_output_artifacts",
    "deviations",
    "failures",
    "limitations",
    "mechanism_maturity_effect",
    "recommended_next_step",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "artifact_type": { "const": "research_finding_record" },
    "record_id": {
      "type": "string",
      "pattern": "^LCMRP-FINDREC-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
    },
    "record_version": { "type": "integer", "minimum": 1 },
    "immutable_record_notice": {
      "const": "Once published, this finding record is immutable. Corrections, reinterpretations, retractions, or new dispositions require a new record version linked to the superseded raw-byte digest."
    },
    "amendment": { "$ref": "#/$defs/amendment" },
    "record_status": { "enum": ["DRAFT", "PUBLISHED", "SUPERSEDED", "RETRACTED"] },
    "finding_id": {
      "type": "string",
      "pattern": "^LCMRP-FIND-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
    },
    "research_layer": { "const": "LAYER_1_FOUNDATIONAL_RESEARCH" },
    "study_reference": { "$ref": "#/$defs/studyReference" },
    "subject_reference": { "$ref": "#/$defs/subjectReference" },
    "primary_method_profile_reference": { "$ref": "#/$defs/profileReference" },
    "analysis_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["analysis_id", "analysis_mode"],
      "properties": {
        "analysis_id": { "$ref": "#/$defs/localId" },
        "analysis_mode": { "enum": ["CONFIRMATORY", "EXPLORATORY"] }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "statement", "scope"],
      "properties": {
        "claim_id": { "$ref": "#/$defs/localId" },
        "statement": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 }
      }
    },
    "terminal_disposition": { "enum": ["COMPLETED", "NOT_RUN", "HALTED", "INVALID"] },
    "result_classification": {
      "enum": ["POSITIVE", "NEGATIVE", "NULL", "MIXED", "INCONCLUSIVE", "INVALID", "NOT_OBSERVED"]
    },
    "claim_assessment": {
      "enum": ["SUPPORTS_CLAIM", "DOES_NOT_SUPPORT_CLAIM", "PARTIALLY_SUPPORTS_CLAIM", "INCONCLUSIVE", "NOT_ASSESSED"]
    },
    "result_assessment_orthogonality_notice": {
      "const": "Result classification and claim assessment are independent fields. A POSITIVE, NEGATIVE, NULL, or MIXED result does not determine whether the scoped claim is supported."
    },
    "finding_statement": { "type": "string", "minLength": 1 },
    "uncertainty": { "type": "string", "minLength": 1 },
    "raw_output_artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/immutableArtifactReference" }
    },
    "deviations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "failures": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "mechanism_maturity_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applicability",
        "mechanism_under_evaluation",
        "may_award_mechanism_evidence_labels",
        "may_change_mechanism_evidence_profile",
        "awarded_mechanism_evidence_labels",
        "rationale"
      ],
      "properties": {
        "applicability": { "const": "NOT_APPLICABLE" },
        "mechanism_under_evaluation": { "const": false },
        "may_award_mechanism_evidence_labels": { "const": false },
        "may_change_mechanism_evidence_profile": { "const": false },
        "awarded_mechanism_evidence_labels": { "const": [] },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "recommended_next_step": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": false
  },
  "allOf": [
    {
      "if": { "properties": { "record_version": { "const": 1 } }, "required": ["record_version"] },
      "then": {
        "properties": {
          "amendment": {
            "properties": {
              "kind": { "const": "INITIAL" },
              "supersedes_record_version": { "type": "null" },
              "supersedes_artifact_digest": { "type": "null" },
              "rationale": { "type": "null" },
              "changed_fields": { "maxItems": 0 }
            }
          }
        }
      },
      "else": {
        "properties": {
          "amendment": {
            "properties": {
              "kind": { "const": "SUPERSEDING_RECORD" },
              "supersedes_record_version": { "type": "integer", "minimum": 1 },
              "supersedes_artifact_digest": { "$ref": "#/$defs/immutableDigest" },
              "rationale": { "type": "string", "minLength": 1 },
              "changed_fields": { "minItems": 1 }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "terminal_disposition": { "enum": ["NOT_RUN", "HALTED"] } },
        "required": ["terminal_disposition"]
      },
      "then": {
        "properties": {
          "result_classification": { "const": "NOT_OBSERVED" },
          "claim_assessment": { "const": "NOT_ASSESSED" },
          "raw_output_artifacts": { "maxItems": 0 },
          "failures": { "minItems": 1 }
        }
      }
    },
    {
      "if": { "properties": { "terminal_disposition": { "const": "INVALID" } }, "required": ["terminal_disposition"] },
      "then": {
        "properties": {
          "result_classification": { "const": "INVALID" },
          "claim_assessment": { "const": "NOT_ASSESSED" },
          "failures": { "minItems": 1 }
        }
      }
    },
    {
      "if": { "properties": { "terminal_disposition": { "const": "COMPLETED" } }, "required": ["terminal_disposition"] },
      "then": {
        "properties": {
          "result_classification": {
            "enum": ["POSITIVE", "NEGATIVE", "NULL", "MIXED", "INCONCLUSIVE"]
          },
          "claim_assessment": {
            "enum": ["SUPPORTS_CLAIM", "DOES_NOT_SUPPORT_CLAIM", "PARTIALLY_SUPPORTS_CLAIM", "INCONCLUSIVE"]
          },
          "raw_output_artifacts": { "minItems": 1 }
        }
      }
    }
  ],
  "$defs": {
    "localId": { "type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]{1,127}$" },
    "amendment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "supersedes_record_version", "supersedes_artifact_digest", "rationale", "changed_fields"],
      "properties": {
        "kind": { "enum": ["INITIAL", "SUPERSEDING_RECORD"] },
        "supersedes_record_version": { "type": ["integer", "null"], "minimum": 1 },
        "supersedes_artifact_digest": {
          "oneOf": [{ "$ref": "#/$defs/immutableDigest" }, { "type": "null" }]
        },
        "rationale": { "type": ["string", "null"], "minLength": 1 },
        "changed_fields": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "studyReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["study_id", "study_record_id", "study_record_version", "manifest_artifact"],
      "properties": {
        "study_id": {
          "type": "string",
          "pattern": "^LCMRP-FSTUDY-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
        },
        "study_record_id": {
          "type": "string",
          "pattern": "^LCMRP-FSTUDYREC-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
        },
        "study_record_version": { "type": "integer", "minimum": 1 },
        "manifest_artifact": {
          "allOf": [
            { "$ref": "#/$defs/immutableArtifactReference" },
            {
              "properties": {
                "schema_id": { "const": "urn:lcmrp:schema:foundational-study-manifest:0.1.0" }
              }
            }
          ]
        }
      }
    },
    "subjectReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_type", "subject_kind", "subject_id", "subject_series", "subject_version", "definition_artifact"],
      "properties": {
        "target_type": { "const": "FOUNDATIONAL_SUBJECT" },
        "subject_kind": {
          "enum": ["MEMORY_TAXONOMY", "FORMAL_MEMORY_MODEL", "COGNITIVE_MEMORY_CONCEPT", "EVALUATION_CONSTRUCT"]
        },
        "subject_id": {
          "type": "string",
          "pattern": "^LCMRP-FSUBJ-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
        },
        "subject_series": { "type": "string", "minLength": 1 },
        "subject_version": { "type": "integer", "minimum": 1 },
        "definition_artifact": { "$ref": "#/$defs/immutableArtifactReference" }
      }
    },
    "profileReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_kind", "profile_id", "profile_series", "profile_version", "profile_artifact"],
      "properties": {
        "profile_kind": { "enum": ["STRUCTURAL_OR_TAXONOMY_EVALUATION", "FORMAL_ANALYSIS"] },
        "profile_id": {
          "type": "string",
          "pattern": "^LCMRP-MPROF-[0-9]{4}-[A-Z0-9][A-Z0-9._-]*$"
        },
        "profile_series": { "type": "string", "minLength": 1 },
        "profile_version": { "type": "integer", "minimum": 1 },
        "profile_artifact": { "$ref": "#/$defs/immutableArtifactReference" }
      }
    },
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "status", "value", "scope"],
      "properties": {
        "algorithm": { "const": "SHA-256" },
        "status": { "enum": ["PENDING", "RECORDED", "VERIFIED"] },
        "value": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "scope": { "const": "RAW_FILE_BYTES" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "PENDING" } }, "required": ["status"] },
          "then": { "properties": { "value": { "type": "null" } } },
          "else": { "properties": { "value": { "type": "string", "pattern": "^[a-f0-9]{64}$" } } }
        }
      ]
    },
    "immutableDigest": {
      "allOf": [
        { "$ref": "#/$defs/digest" },
        { "properties": { "status": { "enum": ["RECORDED", "VERIFIED"] }, "value": { "type": "string" } } }
      ]
    },
    "artifactReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "artifact_version", "schema_id", "locator", "digest", "media_type"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/localId" },
        "artifact_version": { "type": "integer", "minimum": 1 },
        "schema_id": { "type": "string", "minLength": 1 },
        "locator": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$" },
        "digest": { "$ref": "#/$defs/digest" },
        "media_type": { "type": "string", "minLength": 1 }
      }
    },
    "immutableArtifactReference": {
      "allOf": [
        { "$ref": "#/$defs/artifactReference" },
        { "properties": { "digest": { "$ref": "#/$defs/immutableDigest" } } }
      ]
    }
  }
}
