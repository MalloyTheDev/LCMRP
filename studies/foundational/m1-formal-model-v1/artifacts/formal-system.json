    "variable": "A JSON string naming one Boolean variable declared by the containing module.",
    "literal": "A JSON Boolean.",
    "not": "{\"not\": expression}",
    "and": "{\"and\": [expression, ...]}",
    "or": "{\"or\": [expression, ...]}",
    "implies": "{\"implies\": [antecedent, consequent]}",
    "iff": "{\"iff\": [left, right]}"
  },
