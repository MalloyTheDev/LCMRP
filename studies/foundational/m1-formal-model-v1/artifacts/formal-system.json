    "module_isolation": true,
    "maximum_variables_in_one_enumerated_module": 16,
    "maximum_valuations_in_one_enumerated_module": 65536,
    "cross_module_product_enumerated": false,
    "rationale": "Module-local exhaustive enumeration is deterministic and tractable, but does not establish a single full FMO structure spanning all modules."
